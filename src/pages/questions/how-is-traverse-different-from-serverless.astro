  title={"How is Traverse different from serverless functions?"}
  description={"Serverless handles event-driven compute that scales to zero. Traverse runs governed business logic in-process with no cold start and a contract-enforced execution model."}
  canonical={"https://traverse-framework.com/questions/how-is-traverse-different-from-serverless.html"}
  category={"Comparisons"}
  relatedLinks={relatedLinks}
  jsonLd={_jsonLd}
>
  <Fragment set:html={_body} />
</QuestionLayout>
