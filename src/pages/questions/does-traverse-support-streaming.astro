import QuestionLayout from '@layouts/QuestionLayout.astro';

const relatedLinks = [];
const _body = "<p>Not in v0.8.1. Traverse currently uses a request-response model: you call a capability with an input, the WASM binary runs to completion, and you get back a complete output. There is no incremental or streaming output in this version.</p>\n\n      <h2>Why the current model is request-response</h2>\n      <p>The contract model is designed around complete, validated inputs and outputs. Preconditions validate the full input before execution starts. Postconditions validate the full output after execution completes. Streaming complicates both of these — you cannot validate a partial output against a schema that expects a complete document.</p>\n      <p>For most business logic use cases — pricing calculations, eligibility checks, rule evaluations — request-response is the right model anyway. The computation finishes in milliseconds and you want the validated result.</p>\n\n      <h2>Where streaming matters</h2>\n      <p>Streaming becomes relevant for the AI pipeline placement target. When a capability is generating text or processing large datasets and feeding results incrementally to an AI agent, waiting for the full output before returning anything adds unnecessary latency. The roadmap includes streaming support specifically for this context.</p>\n\n      <h2>What streaming in Traverse would look like</h2>\n      <p>The design challenge is handling postconditions on streamed output. One approach is to validate each chunk against a chunk schema rather than a document schema. Another is to run postconditions on the complete assembled output after the stream ends. The exact design has not been finalized. If you have a use case that needs streaming, open a GitHub issue — real-world requirements help shape the design.</p>\n\n      <h2>Events as an alternative</h2>\n      <p>Traverse does support emitting events during capability execution via the emitting_events state. Events are not the same as streaming output, but they can communicate progress or intermediate results back to the caller without blocking on full completion. See <a href=\"/questions/how-does-traverse-handle-events.html\">how Traverse handles events</a> for more.</p>\n\n      <p>See the <a href=\"/questions/what-is-traverse-roadmap.html\">roadmap</a> for the current status of streaming support.</p>";
const _jsonLd = "{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Does Traverse support streaming?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Traverse v0.8.1 uses a request-response model. A capability call takes an input and returns a complete output. Streaming output is not supported in the current version. The roadmap includes streaming support, particularly for the AI pipeline placement target where incremental output is useful.\"}}]}";
---
<QuestionLayout
  title={"Does Traverse support streaming?"}
  description={"Traverse v0.8.1 uses a request-response model. Streaming output from capabilities is on the roadmap. Learn the current execution model and what streaming would look like."}
  canonical={"https://traverse-framework.com/questions/does-traverse-support-streaming.html"}
  category={"Technical Edge Cases"}
  relatedLinks={relatedLinks}
  jsonLd={_jsonLd}
>
  <Fragment set:html={_body} />
