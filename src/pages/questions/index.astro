---
<SubpageLayout
  title={"Frequently Asked Questions — Traverse Framework"}
  description={"Answers to common questions about Traverse: contracts, capabilities, the runtime, AI agent integration, and how it compares to other approaches."}
  canonical={"https://traverse-framework.com/questions.html"}
  crumbs={[{ label: "Home", href: "/" }]}
>
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-inner">
          <span class="section-label">Questions</span>
          <h1 class="t-h1">Answers to common questions.</h1>
          <p class="page-hero-sub">Contracts, capabilities, the runtime, AI agent integration, and how Traverse compares to what you already know.</p>
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        {groups.map((g) => (
          <div style="margin-bottom:3rem">
            <div class="section-label" style="margin-bottom:1rem">{g.label}</div>
            <ul style="list-style:none;padding:0;margin:0;display:grid;grid-template-columns:1fr 1fr;gap:0.25rem 2rem">
              {g.items.map(([slug, title]) => (
                <li>
                  <a href={`/questions/${slug}`} style="display:block;padding:0.6rem 0;color:var(--fg-muted);border-bottom:1px solid var(--border);font-size:0.9rem;text-decoration:none">{title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </main>
</SubpageLayout>
