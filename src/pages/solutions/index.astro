---
import SubpageLayout from '@layouts/SubpageLayout.astro';

const solutions = [
  { href: '/solutions/fintech.html', title: 'Fintech', desc: 'Auditable, contract-governed financial logic with a trace artifact for every execution.' },
  { href: '/solutions/saas.html', title: 'SaaS Platforms', desc: 'One business rule, every runtime — no more drift between the app, the API, and the billing worker.' },
  { href: '/solutions/ecommerce.html', title: 'E-commerce', desc: 'Pricing, eligibility, and promotions logic that behaves identically across every surface, without drift.' },
  { href: '/solutions/enterprise.html', title: 'Enterprise', desc: 'Consistent business logic at scale, governed by versioned contracts instead of tribal knowledge.' },
  { href: '/solutions/ai-companies.html', title: 'AI Companies', desc: 'Governed capabilities AI agents can call safely, with contract boundaries the agent cannot exceed.' },
];
---
<SubpageLayout
  title={"Solutions — Traverse Framework"}
  description={"How teams in fintech, SaaS, e-commerce, enterprise, and AI use Traverse for governed business logic."}
  canonical={"https://traverse-framework.com/solutions.html"}
  crumbs={[{ label: "Home", href: "/" }]}
>
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-inner">
          <span class="section-label">Solutions</span>
          <h1 class="t-h1">Built for how your team actually works.</h1>
          <p class="page-hero-sub">Same contract-governed runtime, applied to the problems that matter most in each industry.</p>
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="usecase-grid">
          {solutions.map((s) => (
            <a href={s.href} class="usecase-card" style="text-decoration:none;display:block">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span style="color:var(--accent);font-size:0.82rem">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</SubpageLayout>
